# Normalize line endings to LF on commit
* text=auto eol=lf

# Explicitly declare text files
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.mjs  text eol=lf
*.json text eol=lf
*.css  text eol=lf
*.md   text eol=lf
*.sql  text eol=lf
*.env* text eol=lf

# Binary files — no conversion
*.png  binary
*.jpg  binary
*.ico  binary
