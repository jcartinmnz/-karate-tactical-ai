# =============================================================
# KarateIQ — Variables de entorno
# Copiar este archivo como .env.local y completar los valores
# =============================================================

# Neon DB (PostgreSQL serverless)
# Obtener desde: https://console.neon.tech → tu proyecto → Connection Details
# Formato: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://usuario:contraseña@ep-xxxxx.us-east-1.aws.neon.tech/karateiq?sslmode=require

# OpenAI API
# Obtener desde: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxx

# Next.js (no modificar)
NEXTAUTH_URL=http://localhost:3000
